# Ansible control node setup
# Copy this file to set up your environment.

# Option 1: Vault password via env var (overrides file-based method)
export ANSIBLE_VAULT_PASSWORD="your-vault-password-here"

# Option 2: Or create the file and it's picked up automatically:
#   mkdir -p ~/.config/ansible
#   echo "your-vault-password" > ~/.config/ansible/krugten-vault-password
#   chmod 600 ~/.config/ansible/krugten-vault-password
